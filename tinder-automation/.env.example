# LLM
UNIFIED_LLM_API_KEY=
TINDER_LLM_API_KEY=
TINDER_LLM_MODEL=MiniMax-M2.7

# Telegram alerts
TINDER_TELEGRAM_BOT_TOKEN=
TINDER_TELEGRAM_CHAT_ID=

# Browser / runtime
TINDER_BROWSER_HEADLESS=true
TINDER_PROFILE_DIR=/Users/chengang/.tinder-automation/browser-profile
TINDER_BROWSER_LOCALE=zh-CN
TINDER_BROWSER_TIMEZONE=Asia/Shanghai
TINDER_VIEWPORT_WIDTH=1280
TINDER_VIEWPORT_HEIGHT=800

# Bot behavior
TINDER_COUNTRY=JP
TINDER_AUTO_LIKE=false
TINDER_AUTO_MESSAGE=true
TINDER_MAX_SESSION_ACTIONS=20
