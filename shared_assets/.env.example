# ============================================
# OpenClaw Tinder/Bumble 自动化配置模板
# ============================================
# 复制此文件为 .env 并填入真实值
# 使用方式: cp .env.example .env

# ============================================
# 必需配置
# ============================================

# LLM API Key（必需）
UNIFIED_LLM_API_KEY=your-api-key-here

# ============================================
# LLM 配置（可选）
# ============================================

# 模型名称
# APP_LLM__MODEL=MiniMax-M2.7

# API 端点
# APP_LLM__BASE_URL=https://api.minimax.chat/v1/text/chatcompletion_v2

# 温度参数（0.0-2.0）
# APP_LLM__TEMPERATURE=0.7

# 最大 token 数
# APP_LLM__MAX_TOKENS=300

# 请求超时（秒）
# APP_LLM__TIMEOUT=30

# 最大重试次数
# APP_LLM__MAX_RETRIES=4

# ============================================
# 浏览器配置（可选）
# ============================================

# 无头模式（true/false）
# APP_BROWSER__HEADLESS=true

# 视口宽度
# APP_BROWSER__VIEWPORT_WIDTH=1280

# 视口高度
# APP_BROWSER__VIEWPORT_HEIGHT=800

# 自定义 User-Agent
# APP_BROWSER__USER_AGENT=

# ============================================
# 代理配置（可选）
# ============================================

# 启用代理（true/false）
# APP_PROXY__ENABLED=false

# 代理服务器（格式：ip:port）
# APP_PROXY__SERVER=

# 代理用户名
# APP_PROXY__USERNAME=

# 代理密码
# APP_PROXY__PASSWORD=

# 会话粘性时长（秒）
# APP_PROXY__STICKY_DURATION=300

# ============================================
# Tinder 配置（可选）
# ============================================

# 启用 Tinder（true/false）
# APP_TINDER__ENABLED=true

# 浏览器配置文件目录
# APP_TINDER__PROFILE_DIR=/Users/yourname/.tinder-automation/browser-profile

# Tinder URL
# APP_TINDER__URL=https://tinder.com

# 单次会话最大操作数
# APP_TINDER__MAX_SESSION_ACTIONS=20

# 冷却时间（分钟）
# APP_TINDER__COOLDOWN_MINUTES=1

# ============================================
# Bumble 配置（可选）
# ============================================

# 启用 Bumble（true/false）
# APP_BUMBLE__ENABLED=true

# 浏览器配置文件目录
# APP_BUMBLE__PROFILE_DIR=/Users/yourname/.bumble-automation/test-profile

# Bumble URL
# APP_BUMBLE__URL=https://bumble.com/app/connections

# 单次会话最大操作数
# APP_BUMBLE__MAX_SESSION_ACTIONS=20

# 冷却时间（分钟）
# APP_BUMBLE__COOLDOWN_MINUTES=1

# ============================================
# 日志配置（可选）
# ============================================

# 日志级别（DEBUG/INFO/WARNING/ERROR/CRITICAL）
# APP_LOG__LEVEL=INFO

# 单文件最大字节数
# APP_LOG__MAX_BYTES=10485760

# 备份文件数
# APP_LOG__BACKUP_COUNT=5

# ============================================
# 应用配置（可选）
# ============================================

# 运行环境（production/development）
# APP_ENV=production

# 调试模式（true/false）
# APP_DEBUG=false

# 工作区目录
# APP_WORKSPACE_DIR=/Users/yourname/.openclaw/workspace/projects

# 演化流水线执行时间（小时，0-23）
# APP_EVOLUTION_HOUR=3

# 宵禁开始时间（小时，0-23）
# APP_CURFEW_START=0

# 宵禁结束时间（小时，0-23）
# APP_CURFEW_END=8
